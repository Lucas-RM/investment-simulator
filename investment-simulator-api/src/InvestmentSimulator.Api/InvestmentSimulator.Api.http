@InvestmentSimulator.Api_HostAddress = http://localhost:5001

### Simular CDB
POST {{InvestmentSimulator.Api_HostAddress}}/simular/cdb
Content-Type: application/json

{
  "initialAmount": 900,
  "startDate": "2026-07-06",
  "endDate": "2026-12-31",
  "contributions": [
    { "date": "2026-08-06", "amount": 900 },
    { "date": "2026-09-06", "amount": 900 },
    { "date": "2026-10-06", "amount": 900 },
    { "date": "2026-11-06", "amount": 900 },
    { "date": "2026-12-06", "amount": 900 }
  ],
  "cdiAnnualRates": [
    { "year": 2026, "rate": 14.15 }
  ],
  "ipcaRates": [
    { "year": 2026, "rate": 4.10 }
  ],
  "cdiPercentage": 1.20
}

###

### Simular Tesouro Selic
POST {{InvestmentSimulator.Api_HostAddress}}/simular/tesouro
Content-Type: application/json

{
  "initialAmount": 10000,
  "startDate": "2026-01-02",
  "endDate": "2026-01-09",
  "contributions": [],
  "selicAnnualRates": [
    { "year": 2026, "rate": 15 }
  ],
  "ipcaRates": [
    { "year": 2026, "rate": 5 }
  ],
  "annualAgioRate": 0.001,
  "b3CustodyRates": [
    { "year": 2026, "rate": 0.2 }
  ]
}

###

### Comparar CDB vs Tesouro
POST {{InvestmentSimulator.Api_HostAddress}}/comparar
Content-Type: application/json

{
  "left": {
    "type": "Cdb",
    "initialAmount": 10000,
    "startDate": "2026-01-02",
    "endDate": "2026-01-09",
    "contributions": [],
    "cdiAnnualRates": [{ "year": 2026, "rate": 15 }],
    "ipcaRates": [{ "year": 2026, "rate": 5 }],
    "cdiPercentage": 1.10
  },
  "right": {
    "type": "TesouroSelic",
    "initialAmount": 10000,
    "startDate": "2026-01-02",
    "endDate": "2026-01-09",
    "contributions": [],
    "selicAnnualRates": [{ "year": 2026, "rate": 15 }],
    "ipcaRates": [{ "year": 2026, "rate": 5 }],
    "annualAgioRate": 0.001,
    "b3CustodyRates": [{ "year": 2026, "rate": 0.2 }]
  }
}

###

### Listar histórico
GET {{InvestmentSimulator.Api_HostAddress}}/historico
Accept: application/json

###

### Salvar no histórico
POST {{InvestmentSimulator.Api_HostAddress}}/historico
Content-Type: application/json

{
  "name": "CDB 120%",
  "date": "2026-07-10",
  "observations": "Cenário base",
  "type": "Cdb",
  "initialAmount": 900,
  "startDate": "2026-07-06",
  "endDate": "2026-12-31",
  "contributions": [],
  "cdiAnnualRates": [{ "year": 2026, "rate": 14.15 }],
  "ipcaRates": [{ "year": 2026, "rate": 4.10 }],
  "cdiPercentage": 1.20
}

